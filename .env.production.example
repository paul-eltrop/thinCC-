# Production env file fuer den Vultr-Deploy. Auf dem Server nach
# /opt/thincc/.env kopieren und mit echten Werten befuellen.
# docker-compose liest diese Datei via env_file ins backend-Container.

# === Supabase ===
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# === Qdrant Cloud ===
QDRANT_URL=
QDRANT_API_KEY=

# === LLMs ===
GOOGLE_API_KEY=
OPENAI_API_KEY=
COHERE_API_KEY=
