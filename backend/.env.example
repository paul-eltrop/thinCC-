# Gemini (Google AI Studio) — Embeddings + LLM
# Key holen unter: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Qdrant Cloud — wenn leer, faellt der Store auf In-Memory zurueck
QDRANT_URL=
QDRANT_API_KEY=

# OpenAI — aktuell nicht aktiv genutzt, vorbereitet fuer GPT-4o als alternativen LLM
OPENAI_API_KEY=

# Cohere — Reranker (rerank-v3.5). Trial-Key reicht fuer Dev/Demo.
# Key holen unter: https://dashboard.cohere.com/api-keys
# Wenn leer: Reranker ist deaktiviert, Retrieval faellt auf reines Embedding zurueck.
COHERE_API_KEY=
